rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow anyone to submit a registration (create only — no reads, no edits, no deletes)
    match /registrations/{docId} {
      allow create: if request.resource.data.keys().hasAll(['firstName', 'lastName', 'email', 'whatsapp', 'batch'])
                    && request.resource.data.firstName is string
                    && request.resource.data.lastName is string
                    && request.resource.data.email is string
                    && request.resource.data.whatsapp is string;
      allow read, update, delete: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
